TELEGRAM_BOT_TOKEN=123456:replace_me

# Free-tier friendly text generation. Create a key at https://console.groq.com/keys
GROQ_API_KEY=replace_me
GROQ_TEXT_MODEL=llama-3.1-8b-instant

# Alternative free-tier friendly text generation. Create a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=replace_me
GEMINI_TEXT_MODEL=gemini-2.0-flash

# Real movie posters, stills, and trailers. Supports v4 Read Access Token or v3 API key.
TMDB_API_KEY=replace_me

# Optional OpenAI fallback for text generation.
OPENAI_API_KEY=sk-replace_me
OPENAI_TEXT_MODEL=gpt-4.1-mini

# Local JSON database path.
DATABASE_PATH=data/movies.json
