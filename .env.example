TELEGRAM_BOT_TOKEN=123456:replace_me
OPENAI_API_KEY=sk-replace_me

# Text generation model. You can swap it for another OpenAI-compatible model.
OPENAI_TEXT_MODEL=gpt-4.1-mini

# Poster generation model. DALL-E 3 returns a public temporary image URL.
OPENAI_IMAGE_MODEL=dall-e-3
OPENAI_IMAGE_SIZE=1024x1792

# Local JSON database path.
DATABASE_PATH=data/movies.json
