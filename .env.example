TELEGRAM_BOT_TOKEN=123456:replace_me

# Free-tier friendly text generation. Create a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=replace_me
GEMINI_TEXT_MODEL=gemini-2.0-flash

# Optional OpenAI fallback for text and poster generation.
OPENAI_API_KEY=sk-replace_me
OPENAI_TEXT_MODEL=gpt-4.1-mini

# Optional poster generation model. If OpenAI has no quota, bot still sends the movie text.
OPENAI_IMAGE_MODEL=dall-e-3
OPENAI_IMAGE_SIZE=1024x1792

# Local JSON database path.
DATABASE_PATH=data/movies.json
